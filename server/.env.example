TMDB_API_KEY=
OPENAI_API_KEY=
PORT=8000

# Comma-separated browser origins allowed to call the API (production: set to your real frontend URL(s))
# ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com

# Set to 1 when running behind a single reverse proxy so rate limits use the real client IP
# TRUST_PROXY=1
